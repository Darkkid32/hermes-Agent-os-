# Hermes Agent OS Environment Variables
#
# SECURITY: No secrets belong in source. Populate the *_KEY / *_TOKEN fields
# locally and never commit a real `.env` file. Only `.env.example` is tracked.

# Server
PORT=4173

# NVIDIA API (required for LLM execution)
# Provision a fresh key from https://build.nvidia.com and paste the value here.
# Hermes will refuse to start an LLM call when this is missing.
NVIDIA_API_KEY=
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_MODEL=meta/llama-3.1-8b-instruct

# Hermes Home Directory
HERMES_HOME=~/.hermes

# Builder
HERMES_BUILDER_PORT=3100
HERMES_ORIGINAL_BUILDER_URL=http://127.0.0.1:3100

# Features
HERMES_AGENT_OS_ENABLE_INSTALL=0
HERMES_AGENT_OS_ENABLE_EXEC=0

# Limits
HERMES_CHAT_HISTORY_LIMIT=20
HERMES_PROJECT_CONTEXT_LIMIT=25000

# Public
HERMES_AGENT_HUB_PUBLIC_URL=
HERMES_AGENT_HUB_GITHUB_REPO=

# Security
#
# HERMES_API_TOKEN — shared bearer token required for all state-changing API
# routes (LLM, modules, edit, terminal, workflows, orchestrator). The frontend
# `server/runtime/auth.js` middleware reads this. Leave empty to disable auth
# (only valid for local development on 127.0.0.1).
HERMES_API_TOKEN=

# Comma-separated list of origins allowed by CORS. Empty = same-origin only.
HERMES_ALLOWED_ORIGINS=http://127.0.0.1:4173,http://localhost:4173

# Rate limit (requests per window) for the LLM proxy. Default = 60.
HERMES_LLM_RATE_LIMIT=60

# Rate limit window in minutes. Default = 1.
HERMES_LLM_RATE_WINDOW=1
